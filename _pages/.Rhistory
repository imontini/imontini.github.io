# --- P7: Norm–real gap by tie and city -----------------------
p7 <- long |>
filter(!is.na(social_tie)) |>
group_by(city_group, social_tie) |>
summarise(gap=mean(norm_real_gap,na.rm=T)*100,
gap_state_down=mean(gap_state_down,na.rm=T)*100,
gap_gang_up=mean(gap_gang_up,na.rm=T)*100, .groups="drop") |>
pivot_longer(c(gap,gap_state_down,gap_gang_up), names_to="type", values_to="pct") |>
mutate(type=recode(type,
gap="Any gap (norm≠real)",
gap_state_down="Norm=state, real≠state",
gap_gang_up="Norm≠gang, real=gang")) |>
ggplot(aes(x=social_tie, y=pct, fill=city_group)) +
geom_col(position="dodge", color="white") +
facet_wrap(~type, ncol=1, scales="free_y") +
scale_fill_manual(values=pal_city) +
labs(title="Norm–real gap: breakdown by social tie and city",
x=NULL, y="%", fill="City") +
theme_minimal(base_size=10) +
theme(legend.position="bottom", plot.title.position="plot",
strip.text=element_text(face="bold"))
