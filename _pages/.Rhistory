auth_real = factor(auth_real, levels=c("State","Gang","Community","Nobody")),
legitimacy = recode(legit_raw,
"1"="State","2"="Gang","3"="Community",
.default = NA_character_),
legitimacy = factor(legitimacy, levels=c("State","Gang","Community")),
# Binary outcomes
chose_state_norm  = as.integer(auth_norm == "State"),
chose_gang_norm   = as.integer(auth_norm == "Gang"),
chose_state_real  = as.integer(auth_real == "State"),
chose_gang_real   = as.integer(auth_real == "Gang"),
legit_state       = as.integer(legitimacy == "State"),
legit_gang        = as.integer(legitimacy == "Gang"),
# Norm–real gap
norm_real_gap  = as.integer(auth_norm != auth_real),
# Specifically: normatively endorsed state but realistically would not go to state
gap_state_down = as.integer(auth_norm=="State" & auth_real!="State"),
# Realistically chose gang even though normatively did not
gap_gang_up    = as.integer(auth_norm!="Gang" & auth_real=="Gang"),
# Competence: 1=resolved, 0=not
competent = case_when(comp_raw=="1"~1L, comp_raw=="2"~0L, TRUE~NA_integer_),
# Risk (numeric 1–3)
risk_num = as.integer(risk_raw)
)
cat("Long dataset:", nrow(long), "obs (", n_distinct(long$resp_id),
"respondents × 6 vignettes)\n")
cat("Missing auth_norm:", sum(is.na(long$auth_norm)),
"  auth_real:", sum(is.na(long$auth_real)), "\n\n")
# ── 4. Treatment balance ─────────────────────────────────────
cat("============================================================\n")
cat("TREATMENT BALANCE\n")
cat("============================================================\n\n")
cat("Social tie × problem type (cell counts):\n")
with(long, print(table(social_tie, problem_type)))
cat("\nCharacter demographics (gender × race):\n")
with(long, print(table(char_gender, char_race)))
cat("\nCity × social tie:\n")
with(long, print(table(city_group, social_tie)))
# ── 5. Outcome distributions ─────────────────────────────────
cat("\n============================================================\n")
cat("OUTCOME DISTRIBUTIONS\n")
cat("============================================================\n\n")
cat("Normative authority choice (% overall):\n")
print(round(prop.table(table(long$auth_norm))*100, 1))
cat("\nRealistic authority choice (% overall):\n")
print(round(prop.table(table(long$auth_real))*100, 1))
cat("\nNorm–real gap:\n")
cat("  Chose state normatively:  ",
round(mean(long$chose_state_norm, na.rm=TRUE)*100,1), "%\n")
cat("  Chose state realistically:",
round(mean(long$chose_state_real, na.rm=TRUE)*100,1), "%\n")
cat("  % where norm ≠ real:      ",
round(mean(long$norm_real_gap,    na.rm=TRUE)*100,1), "%\n")
cat("  Gap (state down):         ",
round(mean(long$gap_state_down,   na.rm=TRUE)*100,1), "%\n")
cat("  Gap (gang up):            ",
round(mean(long$gap_gang_up,      na.rm=TRUE)*100,1), "%\n")
cat("\nLegitimacy (who should be responsible %):\n")
print(round(prop.table(table(long$legitimacy))*100, 1))
cat("\nCompetence (problem would be resolved %):\n")
print(round(prop.table(table(long$competent))*100, 1))
cat("\nRisk level (%):\n")
print(round(prop.table(table(long$risk_num))*100, 1))
# ── 6. Crosstabs by treatment ────────────────────────────────
cat("\n============================================================\n")
cat("OUTCOMES BY KEY TREATMENTS\n")
cat("============================================================\n\n")
make_summary <- function(df, grp_var) {
df |>
filter(!is.na(.data[[grp_var]])) |>
group_by(.data[[grp_var]]) |>
summarise(
n              = n(),
`State (norm) %`  = round(mean(chose_state_norm, na.rm=TRUE)*100, 1),
`Gang (norm) %`   = round(mean(chose_gang_norm,  na.rm=TRUE)*100, 1),
`State (real) %`  = round(mean(chose_state_real, na.rm=TRUE)*100, 1),
`Gang (real) %`   = round(mean(chose_gang_real,  na.rm=TRUE)*100, 1),
`Gap % (≠)`    = round(mean(norm_real_gap,    na.rm=TRUE)*100, 1),
`Legit state %`   = round(mean(legit_state,      na.rm=TRUE)*100, 1),
`Legit gang %`    = round(mean(legit_gang,       na.rm=TRUE)*100, 1),
`Competent %`  = round(mean(competent,        na.rm=TRUE)*100, 1),
`Mean risk`    = round(mean(risk_num,         na.rm=TRUE), 2),
.groups = "drop"
) |>
rename(!!grp_var := 1)
}
cat("By social tie:\n")
print(as.data.frame(make_summary(long, "social_tie")))
cat("\nBy problem type:\n")
print(as.data.frame(make_summary(long, "problem_type")))
cat("\nBy city:\n")
print(as.data.frame(make_summary(long, "city_group")))
cat("\nBy character race:\n")
print(as.data.frame(make_summary(long, "char_race")))
cat("\nBy character gender:\n")
print(as.data.frame(make_summary(long, "char_gender")))
cat("\nSocial tie × problem type — % chose state (normative):\n")
tie_prob <- long |>
filter(!is.na(social_tie), !is.na(problem_type)) |>
group_by(social_tie, problem_type) |>
summarise(
n                = n(),
`State (norm) %` = round(mean(chose_state_norm, na.rm=TRUE)*100, 1),
`Gang (norm) %`  = round(mean(chose_gang_norm,  na.rm=TRUE)*100, 1),
`State (real) %` = round(mean(chose_state_real, na.rm=TRUE)*100, 1),
.groups = "drop"
)
print(as.data.frame(tie_prob))
cat("\nSocial tie × city — % chose state (normative):\n")
tie_city <- long |>
filter(!is.na(social_tie), !is.na(city_group)) |>
group_by(city_group, social_tie) |>
summarise(
n                = n(),
`State (norm) %` = round(mean(chose_state_norm, na.rm=TRUE)*100, 1),
`Gang (norm) %`  = round(mean(chose_gang_norm,  na.rm=TRUE)*100, 1),
`Gap % (≠)`   = round(mean(norm_real_gap,    na.rm=TRUE)*100, 1),
.groups = "drop"
)
print(as.data.frame(tie_city))
# ── 7. AMCEs — pooled and by city ───────────────────────────
# AMCEs = OLS on binary outcomes with all randomized attributes.
# city_group is NOT a randomized attribute; it goes in subgroup models only.
# Reference: social_tie=No tie, problem=robbery, race=White, gender=M, age=40
cat("\n============================================================\n")
cat("AMCEs — AVERAGE MARGINAL COMPONENT EFFECTS\n")
cat("OLS, cluster-robust SE by respondent\n")
cat("Reference: No tie / robbery / White / male / age 40\n")
cat("============================================================\n\n")
rhs <- "social_tie + problem_type + char_gender + char_race + char_age_f"
make_fml <- function(lhs) as.formula(paste(lhs, "~", rhs))
m_state_norm  <- feols(make_fml("chose_state_norm"),  data=long, cluster=~resp_id)
m_gang_norm   <- feols(make_fml("chose_gang_norm"),   data=long, cluster=~resp_id)
m_state_real  <- feols(make_fml("chose_state_real"),  data=long, cluster=~resp_id)
m_gap         <- feols(make_fml("norm_real_gap"),      data=long, cluster=~resp_id)
m_risk        <- feols(make_fml("risk_num"),           data=long, cluster=~resp_id)
m_comp        <- feols(make_fml("competent"),          data=long, cluster=~resp_id)
m_legit_state <- feols(make_fml("legit_state"),        data=long, cluster=~resp_id)
m_legit_gang  <- feols(make_fml("legit_gang"),         data=long, cluster=~resp_id)
# Subgroup: SP and RJ separately
long_sp <- filter(long, city_group == "SP")
long_rj <- filter(long, city_group == "RJ")
m_state_norm_sp <- feols(make_fml("chose_state_norm"), data=long_sp, cluster=~resp_id)
m_state_norm_rj <- feols(make_fml("chose_state_norm"), data=long_rj, cluster=~resp_id)
m_gang_norm_sp  <- feols(make_fml("chose_gang_norm"),  data=long_sp, cluster=~resp_id)
m_gang_norm_rj  <- feols(make_fml("chose_gang_norm"),  data=long_rj, cluster=~resp_id)
coef_labels <- c(
"social_tiePolice tie"    = "Tie: Police",
"social_tieCommunity tie" = "Tie: Community leader",
"social_tieGang tie"      = "Tie: Gang",
"problem_typewater"       = "Problem: water",
"problem_typegbv"         = "Problem: GBV",
"char_genderF"            = "Character: female",
"char_raceBlack"          = "Character: Black",
"char_age_f20"            = "Character age: 20",
"char_age_f60"            = "Character age: 60"
)
cat("\nPooled AMCEs:\n")
msummary(
list(
"State\n(norm)"   = m_state_norm,
"Gang\n(norm)"    = m_gang_norm,
"State\n(real)"   = m_state_real,
"Norm-real\ngap"  = m_gap,
"Risk"            = m_risk,
"Competence"      = m_comp,
"Legit:\nstate"   = m_legit_state,
"Legit:\ngang"    = m_legit_gang
),
stars = c("*"=0.1, "**"=0.05, "***"=0.01),
gof_omit = "IC|Log|Adj|Pseudo|Within|FE",
coef_rename = coef_labels,
output = "markdown"
)
cat("\nSP vs RJ — chose state (normative):\n")
msummary(
list("State norm (SP)"=m_state_norm_sp, "State norm (RJ)"=m_state_norm_rj,
"Gang norm (SP)"=m_gang_norm_sp,   "Gang norm (RJ)"=m_gang_norm_rj),
stars = c("*"=0.1, "**"=0.05, "***"=0.01),
gof_omit = "IC|Log|Adj|Pseudo|Within|FE",
coef_rename = coef_labels,
output = "markdown"
)
# ── 8. Interaction: social tie × problem type ────────────────
cat("\n============================================================\n")
cat("INTERACTION: Social tie × Problem type\n")
cat("============================================================\n\n")
m_interact_state <- feols(
chose_state_norm ~ social_tie * problem_type + char_gender + char_race + char_age_f,
data=long, cluster=~resp_id)
summary(m_interact_state)
m_interact_gang <- feols(
chose_gang_norm ~ social_tie * problem_type + char_gender + char_race + char_age_f,
data=long, cluster=~resp_id)
summary(m_interact_gang)
# ── 9. Visualizations ────────────────────────────────────────
pal_tie  <- c("No tie"="#999999","Police tie"="#2166ac",
"Community tie"="#4dac26","Gang tie"="#d6604d")
pal_auth <- c("State"="#2166ac","Gang"="#d6604d",
"Community"="#4dac26","Nobody"="#bbbbbb")
pal_city <- c("SP"="#2166ac","RJ"="#d6604d")
pal_prob <- c("robbery"="#d6604d","water"="#2166ac","gbv"="#984ea3")
# --- P1: Stacked bar — normative choice by social tie --------
p1 <- long |>
filter(!is.na(social_tie), !is.na(auth_norm)) |>
count(social_tie, auth_norm) |>
group_by(social_tie) |>
mutate(pct = n/sum(n)*100) |>
ggplot(aes(x=social_tie, y=pct, fill=auth_norm)) +
geom_col(color="white", linewidth=0.3) +
scale_fill_manual(values=pal_auth) +
labs(title="Normative authority choice by social tie",
subtitle="Who should the vignette character contact?",
x=NULL, y="% of vignettes", fill=NULL) +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot")
# --- P2: Norm vs real — % chose state, by social tie ---------
p2 <- long |>
filter(!is.na(social_tie)) |>
group_by(social_tie) |>
summarise(Normative=mean(chose_state_norm,na.rm=T)*100,
Realistic=mean(chose_state_real,na.rm=T)*100, .groups="drop") |>
pivot_longer(-social_tie, names_to="Frame", values_to="pct") |>
ggplot(aes(x=social_tie, y=pct, fill=Frame)) +
geom_col(position="dodge", color="white") +
scale_fill_manual(values=c("Normative"="#2166ac","Realistic"="#92c5de")) +
labs(title="% chose state: normative ('should') vs. realistic ('would')",
x=NULL, y="% chose state authority", fill=NULL) +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot")
# --- P3: % chose state by social tie × problem type ----------
p3 <- long |>
filter(!is.na(social_tie), !is.na(problem_type)) |>
group_by(social_tie, problem_type) |>
summarise(pct_state=mean(chose_state_norm,na.rm=T)*100, .groups="drop") |>
ggplot(aes(x=social_tie, y=pct_state,
color=problem_type, group=problem_type)) +
geom_line(linewidth=1) +
geom_point(size=3) +
scale_color_manual(values=pal_prob,
labels=c(robbery="Robbery",water="Water access",gbv="GBV")) +
labs(title="% chose state — by social tie × problem type",
x=NULL, y="% chose state (normative)", color="Problem type") +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot")
# --- P4: AMCE forest plot — all attributes, main outcomes ----
attr_levels <- c(
# Social tie
"Police tie", "Community tie", "Gang tie",
# Problem type
"water", "gbv",
# Character
"F", "Black", "20", "60"
)
attr_labels <- c(
"Police tie"    = "Social tie: Police",
"Community tie" = "Social tie: Community leader",
"Gang tie"      = "Social tie: Gang",
"water"         = "Problem: water access",
"gbv"           = "Problem: GBV",
"F"             = "Character: female",
"Black"         = "Character: Black",
"20"            = "Character age: 20",
"60"            = "Character age: 60"
)
attr_groups <- c(
"Police tie"="Social tie","Community tie"="Social tie","Gang tie"="Social tie",
"water"="Problem type","gbv"="Problem type",
"F"="Character","Black"="Character","20"="Character","60"="Character"
)
extract_amces <- function(model_list) {
map_dfr(model_list, function(m) {
broom::tidy(m, conf.int=TRUE, conf.level=0.9) |>
filter(term != "(Intercept)") |>
mutate(
term = str_remove(term, "social_tie|problem_type|char_gender|char_race|char_age_f")
) |>
filter(term %in% attr_levels)
}, .id = "outcome")
}
amce_df <- extract_amces(list(
"State (norm)"  = m_state_norm,
"Gang (norm)"   = m_gang_norm,
"State (real)"  = m_state_real,
"Norm-real gap" = m_gap,
"Legit: state"  = m_legit_state,
"Legit: gang"   = m_legit_gang
)) |>
mutate(
term   = factor(term, levels = rev(attr_levels)),
label  = attr_labels[as.character(term)],
group  = attr_groups[as.character(term)],
label  = factor(label, levels = rev(attr_labels)),
outcome = factor(outcome, levels = c(
"State (norm)","Gang (norm)","State (real)",
"Norm-real gap","Legit: state","Legit: gang"))
)
p4 <- ggplot(amce_df, aes(x=estimate, y=label, color=outcome)) +
geom_vline(xintercept=0, linetype="dashed", color="grey50") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high),
position=position_dodge(0.7),
linewidth=0.7, size=0.35) +
scale_color_brewer(palette="Dark2") +
facet_grid(group ~ ., scales="free_y", space="free_y",
labeller=labeller(group=label_value)) +
labs(
title    = "AMCEs: average marginal component effects",
subtitle = "OLS, 90% CI, clustered by respondent; reference = no tie / robbery / White / male / age 40",
x = "Change in Pr(outcome)", y = NULL, color = "Outcome"
) +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot",
strip.text.y=element_text(angle=0, face="bold"),
panel.spacing=unit(0.4,"lines"))
# --- P4b: AMCE by city (chose state, normative) ---------------
amce_city_df <- bind_rows(
broom::tidy(m_state_norm_sp, conf.int=TRUE, conf.level=0.9) |>
mutate(city="SP"),
broom::tidy(m_state_norm_rj, conf.int=TRUE, conf.level=0.9) |>
mutate(city="RJ")
) |>
filter(term != "(Intercept)") |>
mutate(
term = str_remove(term, "social_tie|problem_type|char_gender|char_race|char_age_f")
) |>
filter(term %in% attr_levels) |>
mutate(
label = attr_labels[term],
group = attr_groups[term],
label = factor(label, levels=rev(attr_labels))
)
p4b <- ggplot(amce_city_df, aes(x=estimate, y=label, color=city)) +
geom_vline(xintercept=0, linetype="dashed", color="grey50") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high),
position=position_dodge(0.6),
linewidth=0.7, size=0.35) +
scale_color_manual(values=pal_city) +
facet_grid(group ~ ., scales="free_y", space="free_y") +
labs(
title    = "AMCEs by city: chose state authority (normative)",
subtitle = "SP vs RJ; 90% CI clustered by respondent",
x = "Change in Pr(chose state)", y = NULL, color = "City"
) +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot",
strip.text.y=element_text(angle=0, face="bold"),
panel.spacing=unit(0.4,"lines"))
# --- P5: SP vs RJ — normative choice by social tie -----------
p5 <- long |>
filter(!is.na(social_tie)) |>
group_by(city_group, social_tie) |>
summarise(pct_state=mean(chose_state_norm,na.rm=T)*100,
pct_gang =mean(chose_gang_norm, na.rm=T)*100, .groups="drop") |>
pivot_longer(c(pct_state,pct_gang),
names_to="outcome",
values_to="pct",
names_prefix="pct_") |>
mutate(outcome=recode(outcome,"state"="State","gang"="Gang")) |>
ggplot(aes(x=social_tie, y=pct, fill=city_group)) +
geom_col(position="dodge", color="white") +
facet_wrap(~outcome, labeller=labeller(outcome=c(State="% chose state",Gang="% chose gang"))) +
scale_fill_manual(values=pal_city) +
labs(title="SP vs RJ — normative choice by social tie",
x=NULL, y="% of vignettes", fill="City") +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot",
strip.text=element_text(face="bold"))
# --- P6: Legitimacy by social tie × city --------------------
