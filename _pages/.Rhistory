geom_point(size=3) +
scale_color_manual(values=pal_prob,
labels=c(robbery="Robbery",water="Water access",gbv="GBV")) +
labs(title="% chose state — by social tie × problem type",
x=NULL, y="% chose state (normative)", color="Problem type") +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot")
ggplot(amce_df, aes(x=estimate, y=label, color=outcome)) +
geom_vline(xintercept=0, linetype="dashed", color="grey50") +
geom_pointrange(aes(xmin=conf.low, xmax=conf.high),
position=position_dodge(0.7),
linewidth=0.7, size=0.35) +
scale_color_brewer(palette="Dark2") +
facet_grid(group ~ ., scales="free_y", space="free_y",
labeller=labeller(group=label_value)) +
labs(
title    = "AMCEs: average marginal component effects",
subtitle = "OLS, 90% CI, clustered by respondent; reference = no tie / robbery / White / male / age 40",
x = "Change in Pr(outcome)", y = NULL, color = "Outcome"
) +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot",
strip.text.y=element_text(angle=0, face="bold"),
panel.spacing=unit(0.4,"lines"))
long |>
filter(!is.na(social_tie), !is.na(legitimacy)) |>
count(social_tie, city_group, legitimacy) |>
group_by(social_tie, city_group) |>
mutate(pct=n/sum(n)*100) |>
ggplot(aes(x=social_tie, y=pct, fill=legitimacy)) +
geom_col(color="white", linewidth=0.3) +
facet_wrap(~city_group) +
scale_fill_manual(values=c("State"="#2166ac","Gang"="#d6604d","Community"="#4dac26")) +
labs(title="Legitimacy attribution by social tie and city",
subtitle="Who should be responsible for handling the problem?",
x=NULL, y="% of vignettes", fill=NULL) +
theme_minimal(base_size=11) +
theme(legend.position="bottom", plot.title.position="plot",
strip.text=element_text(face="bold"))
View(df_raw)
